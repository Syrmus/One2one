# Copy this to .env.production and fill in real values. Never commit .env.production.
#
# Used both for docker-compose.prod.yml's ${VAR} substitution and (via the
# backend's `env_file:`) as the backend container's runtime environment — see
# DEPLOY.md for the exact `docker compose --env-file .env.production ...` command
# this depends on.

# --- Postgres --- (internal only, no host port — see docker-compose.prod.yml)
POSTGRES_USER=weave
POSTGRES_PASSWORD=change-me-to-a-long-random-value
POSTGRES_DB=weave

# --- Backend ---
# "postgres" is the Compose service name (internal Docker DNS), not localhost.
# User/password/db here must match the three POSTGRES_* values above.
DATABASE_URL=postgres://weave:change-me-to-a-long-random-value@postgres:5432/weave
PORT=3001
# Public origin the app is actually served from (see DEPLOY.md's Nginx snippet) —
# both the frontend and API are reached through this one domain.
WEB_ORIGIN=https://weave.example.com
BETTER_AUTH_URL=https://weave.example.com
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
# Register a *second* Google OAuth client for this domain (the existing one is
# registered for localhost) — see DEPLOY.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Frontend (build-time only — baked into the static bundle, not read at runtime) ---
# Same origin as WEB_ORIGIN/BETTER_AUTH_URL above, since the host Nginx path-routes
# /api/* to the backend and everything else to the frontend on one domain.
VITE_API_URL=https://weave.example.com
