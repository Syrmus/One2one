  "topic": "история",
  "title": "Мёд, который не умирает",
  "units": [
    {
      "t": "weave",
      "l1": "Мёд",
      "l2": "honing",
      "lemma": "honing",
      "pos": "noun",
      "gender": "c",
      "gloss": "мёд",
      "ipa": "ˈɦoːnɪŋ",
      "weave_priority": 1
    },
    {
      "t": "text",
      "l1": " — одна из немногих вещей в "
    },
    {
      "t": "weave",
      "l1": "мире",
      "l2": "wereld",
      "lemma": "wereld",
      "pos": "noun",
      "gender": "c",
      "gloss": "мир",
      "ipa": "ˈʋeːrəlt",
      "weave_priority": 2
    },
    {
      "t": "text",
      "l1": ", которая никогда не портится. Однажды "
    },
    {
      "t": "weave",
      "l1": "археологи",
      "l2": "archeologen",
      "lemma": "archeoloog",
      "pos": "noun",
      "gender": "c",
      "gloss": "археолог",
      "ipa": "ɑrxeːoːˈloːx",
      "weave_priority": 3
