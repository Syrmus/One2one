    },
    {
      "t": "weave",
      "l1": "гробницу",
      "l2": "graf",
      "lemma": "graf",
      "pos": "noun",
      "gender": "n",
      "gloss": "гробница",
      "ipa": "ɣrɑf",
      "weave_priority": 3
    },
