    {
      "t": "weave",
      "l1": "официантах",
      "l2": "camareros",
      "lemma": "camarero",
      "pos": "noun",
      "gender": "m",
      "gloss": "официант",
      "ipa": "kamaˈreɾo",
      "weave_priority": 4
