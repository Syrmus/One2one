  "l2": "es",
  "level": "B1",
  "topic": "история",
  "title": "Мёд, который не умирает",
  "units": [
    {
      "t": "weave",
      "l1": "Мёд",
      "l2": "miel",
      "lemma": "miel",
      "pos": "noun",
      "gender": "f",
      "gloss": "мёд",
      "ipa": "mjel",
      "weave_priority": 1
    },
    {
      "t": "text",
      "l1": " — одна из немногих вещей в "
    },
    {
      "t": "weave",
      "l1": "мире",
      "l2": "mundo",
      "lemma": "mundo",
      "pos": "noun",
      "gender": "m",
      "gloss": "мир",
      "ipa": "ˈmundo",
      "weave_priority": 2
    },
    {
      "t": "text",
      "l1": ", которая никогда не портится. Однажды "
    },
    {
      "t": "weave",
      "l1": "археологи",
      "l2": "arqueólogos",
      "lemma": "arqueólogo",
      "pos": "noun",
      "gender": "m",
      "gloss": "археолог",
      "ipa": "aɾkeˈoloɣo",
      "weave_priority": 3
    },
    {
      "t": "text",
      "l1": " вскрыли древнюю египетскую "
    },
    {
      "t": "weave",
      "l1": "гробницу",
      "l2": "tumba",
      "lemma": "tumba",
      "pos": "noun",
      "gender": "f",
      "gloss": "гробница",
      "ipa": "ˈtumba",
      "weave_priority": 3
    },
    {
      "t": "text",
      "l1": " и нашли внутри глиняную "
